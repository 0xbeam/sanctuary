# Database
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Google OAuth (for calendar sync)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/google/callback"
GOOGLE_CALENDAR_IDS="primary"

# OpenAI
OPENAI_API_KEY=""

# Deepgram (for live transcription)
DEEPGRAM_API_KEY=""

# Transcription mode: deepgram | captions | both
TRANSCRIPTION_MODE="both"

# Backblaze B2 (recording storage)
B2_APPLICATION_KEY_ID=""
B2_APPLICATION_KEY=""
B2_BUCKET_NAME="atlas-recordings"

# Bot config
BOT_NAME="Atlas Notetaker"
BOT_EMAIL=""
BOT_AUTH_COOKIE_PATH="./auth.json"

# Backend
PORT=3001
DASHBOARD_URL="http://localhost:3000"

# Embedding
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS=1536
