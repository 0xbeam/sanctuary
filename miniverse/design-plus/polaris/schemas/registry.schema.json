{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "registry.schema.json",
  "title": "Component Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "components"
  ],
  "properties": {
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/defs/component"
      }
    }
  },
  "defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "source",
        "slots"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "propsSchema": {
          "type": "string"
        },
        "slots": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "kind"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              },
              "semanticRole": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
